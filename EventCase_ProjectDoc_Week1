description	TEXT		Full event description
category_id	INT	FK → categories	Event category
venue_id	INT	FK → venues	Venue of the event
organizer_id	INT	FK → users	Organizer (user) who created it
start_date	DATETIME	NOT NULL	Event start date and time
end_date	DATETIME	NOT NULL	Event end date and time
capacity	INT	NOT NULL	Maximum attendees allowed
status	ENUM	NOT NULL	draft / published / cancelled / completed
 
